# --- Qwen Cloud (DashScope, intl) ---
QWEN_API_KEY=replace_me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_VIDEO_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# --- Model IDs (centralized; lock from docs/verified_models.md after Task 0.2) ---
QWEN_TEXT_MODEL=qwen3.7-plus
QWEN_VISION_MODEL=qwen3.7-plus
WAN_T2V_MODEL=wan2.7-t2v
WAN_I2V_MODEL=wan2.7-i2v
WAN_R2V_MODEL=wan2.7-r2v
WAN_VIDEOEDIT_MODEL=wan2.7-videoedit

# --- Alibaba Cloud (OSS storage = deployment proof) ---
ALIBABA_CLOUD_REGION=replace_me
ALIBABA_CLOUD_OSS_BUCKET=replace_me
ALIBABA_CLOUD_ACCESS_KEY_ID=replace_me
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace_me

# --- App ---
DATABASE_URL=sqlite:///./circle_take.db  # prod: postgresql://USER:PW@HOST/DB (Neon)
APP_ENV=development  # development | fixture | live

# --- Auth (email + password, JWT) ---
JWT_SECRET=replace_me  # 32+ bytes; generate with: openssl rand -hex 32
JWT_TTL_MINUTES=10080  # access-token lifetime in minutes (default 7 days)
