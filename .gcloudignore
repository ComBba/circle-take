# Keep the Cloud Build upload small. Include only what the Dockerfile COPYs:
# backend, examples, frontend, and the 4 demo media files (take1/take2 clips+frames).
.git/
.gitignore
scripts/
docs/
claudedocs/
deployment/
node_modules/
.venv*/
**/.venv/
__pycache__/
**/__pycache__/
.pytest_cache/
.ruff_cache/
.DS_Store
.env
.env.local

# Exclude all artifacts EXCEPT the 4 demo media files the UI plays.
artifacts/*
!artifacts/live
artifacts/live/*
!artifacts/live/take1_S02.mp4
!artifacts/live/take2_S02.mp4
!artifacts/live/take1_frame.png
!artifacts/live/take2_frame.png
